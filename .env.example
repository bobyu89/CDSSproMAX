# Copy this file to .env and fill in real values. NEVER commit .env.

# === Database ===
POSTGRES_USER=ticdss
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=ticdss
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://ticdss:change_me_locally@localhost:5433/ticdss

# === LLM API keys ===
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# === Model IDs ===
S_AGENT_MODEL=claude-opus-4-7
E_AGENT_MODEL=gemini-3.5-flash
A_AGENT_MODEL=gemini-3.5-flash
V_AGENT_MODEL=gemini-3.5-flash

# === ASR service ===
ASR_SERVICE_URL=http://localhost:8002
BREEZE_MODEL_ID=MediaTek-Research/Breeze-ASR-25

# === Langfuse ===
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# === Embeddings / RAG ===
EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# === Audit log ===
AUDIT_LOG_DIR=./audit_logs

# === Keyframe object storage (MinIO / S3) ===
# Set STORAGE_BACKEND=none to disable (keyframes still scored but not persisted).
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=ticdss
S3_SECRET_ACCESS_KEY=change_me_locally
S3_BUCKET=ticdss-keyframes
S3_PUBLIC_BASE_URL=http://localhost:9000/ticdss-keyframes

# === Auth ===
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=12
