      "weight": 1.0,
      "max_score": 5,
      "criteria": [
        { "level": 5, "descriptor": "完成四個聽診區（主動脈、肺動脈、Erb's point、二尖瓣），順序正確，使用聽診器膜面與鐘面分別評估，能正確描述 S1/S2 與雜音特徵" },
