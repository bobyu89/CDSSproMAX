        { "level": 2, "descriptor": "僅聽診單一位置，未系統性涵蓋" },
        { "level": 1, "descriptor": "嘗試聽診但位置或姿勢明顯錯誤" },
        { "level": 0, "descriptor": "未執行心臟聽診" }
      ],
      "evidence_anchors": ["聽診", "心音", "S1", "S2", "雜音", "膜面", "鐘面"]
